{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",       // ← change
    "moduleResolution": "Node", // ← change
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}